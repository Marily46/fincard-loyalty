{
  "name": "fincard-loyalty",
  "version": "1.0.0",
  "description": "FinCard - Módulo de Liquidación de Puntos y Aliados (Prueba Técnica Ceiba)",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
